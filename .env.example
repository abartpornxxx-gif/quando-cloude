NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Prisma connection strings — Supabase > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Dati impresa — usati nella DiCo e nell'export XML SdI (Fase 5)
IMPRESA_RAGIONE_SOCIALE="Nome Impresa S.r.l."
IMPRESA_PARTITA_IVA="12345678901"
IMPRESA_INDIRIZZO="Via Roma 1"
IMPRESA_CAP="00100"
IMPRESA_CITTA="Roma"
IMPRESA_PROVINCIA="RM"
IMPRESA_IBAN="IT60 X054 2811 1010 0000 0123 456"

# Email (opzionale — attivare con npm install resend)
# RESEND_API_KEY=re_xxxx

# Push notification (opzionale — attivare con npm install web-push)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com
