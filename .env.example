# ─── Supabase (obbligatorio) ──────────────────────────────────────────────────
# Trovare in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase Admin (obbligatorio per Fase 12 — Creazione accessi) ─────────────
# Trovare in: Supabase Dashboard > Project Settings > API > service_role (secret)
# ATTENZIONE: questa chiave bypassa le RLS. Usarla SOLO in server actions / route API.
# Mai committarla, mai esporla al client, mai inserirla in variabili NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database Prisma (obbligatorio) ───────────────────────────────────────────
# Trovare in: Supabase Dashboard > Project Settings > Database > Connection string
# DATABASE_URL: usa "Transaction pooler" (porta 6543), parametro pgbouncer=true
DATABASE_URL="postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ─── Dati impresa (obbligatorio) ──────────────────────────────────────────────
# Usati in: DiCo DM 37/2008, export XML SdI, portale cliente (pagamenti)
IMPRESA_RAGIONE_SOCIALE="Nome Impresa S.r.l."
IMPRESA_PARTITA_IVA="12345678901"
IMPRESA_INDIRIZZO="Via Roma 1"
IMPRESA_CAP="00100"
IMPRESA_CITTA="Roma"
IMPRESA_PROVINCIA="RM"
IMPRESA_IBAN="IT60 X054 2811 1010 0000 0123 456"

# ─── URL dell'app (obbligatorio in produzione) ────────────────────────────────
# Inserire l'URL Vercel dopo il primo deploy (es. https://quadro-xxx.vercel.app)
NEXT_PUBLIC_APP_URL=https://tuoapp.vercel.app

# ─── Super Admin (obbligatorio per il pannello /admin/) ──────────────────────
# Inserire l'email del proprietario della piattaforma.
# Solo questo indirizzo ha accesso a /admin/.
# ATTENZIONE: cambiare questa email richiede anche un nuovo deploy Vercel.
SUPERADMIN_EMAIL=tua@email.it

# ─── Assistente AI (opzionale ma consigliato) ────────────────────────────────
# Provider: Groq (gratuito, veloce). Ottieni chiave su https://console.groq.com
# 1. Vai su console.groq.com → crea account gratuito → API Keys → Create API Key
# 2. Incolla la chiave qui sotto e su Vercel (Project Settings > Environment Variables)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
#
# Provider alternativo OpenRouter (modelli gratis disponibili):
# AI_API_KEY=sk-or-v1-xxxx
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=google/gemma-2-9b-it:free
#
# Provider alternativo OpenAI:
# AI_API_KEY=sk-proj-xxxx
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# ─── Email con Resend (opzionale) ─────────────────────────────────────────────
# PER ATTIVARE: npm install resend  poi aggiungere le chiavi qui sotto
# Trovare in: resend.com > API Keys
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=QUADRO <notifiche@tuodominio.it>

# ─── Push notification Web Push (opzionale) ───────────────────────────────────
# PER ATTIVARE: npm install web-push  poi generare le chiavi VAPID:
#   node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:info@tuaimpresa.it
