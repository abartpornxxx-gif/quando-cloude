// QUADRO — Schema Prisma

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (specchia Supabase) ────────────────────────────────────────────────

enum UserRole {
  impresa
  operaio
  cliente
  magazziniere
  ufficio
}

model Profile {
  id        String   @id @db.Uuid
  role      UserRole @default(cliente)
  fullName  String?  @map("full_name")
  email     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("profiles")
}

// ─── Anagrafiche ─────────────────────────────────────────────────────────────

model Cliente {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome               String
  partitaIva         String?         @map("partita_iva")
  codiceFiscale      String?         @map("codice_fiscale")
  indirizzo          String?
  citta              String?
  cap                String?
  provincia          String?
  email              String?
  telefono           String?
  pec                String?
  codiceDestinatario String?         @map("codice_destinatario")
  note               String?
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  preventivi         Preventivo[]
  commesse           Commessa[]
  fattureAttive      FatturaAttiva[]
  richiesteOfferte   RichiestaOfferta[]
  manutenzioni       ManutenzioneProgrammata[]
  proposteIntervento PropostaIntervento[]

  @@map("clienti")
}

model Fornitore {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String
  partitaIva    String?           @map("partita_iva")
  codiceFiscale String?           @map("codice_fiscale")
  indirizzo     String?
  citta         String?
  cap           String?
  provincia     String?
  email         String?
  telefono      String?
  pec           String?
  note          String?
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  ordini          OrdineFornitore[]
  fatturePassive  FatturaPassiva[]

  @@map("fornitori")
}

model Operaio {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome        String
  email       String?  @unique
  ruolo       String?
  costoOrario Int               @default(0) @map("costo_orario")
  zona        String?
  skills      Json              @default("[]")
  note        String?
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  commesse          CommessaOperaio[]
  giornate          Giornata[]
  pianificazioni    Pianificazione[]
  assenze           Assenza[]
  attrezzatureUsi   AttrezzaturaUso[]
  richiesteMateriale RichiestaMateriale[]

  @@map("operai")
}

model Magazziniere {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome      String
  email     String?  @unique
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("magazzinieri")
}

model CollaboratoreUfficio {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome      String
  email     String?  @unique
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("collaboratori_ufficio")
}

enum StatoMezzo {
  disponibile
  in_uso
  in_manutenzione
  fuori_servizio
}

model Mezzo {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome                  String
  targa                 String?
  stato                 StatoMezzo @default(disponibile)
  scadenzaBollo         DateTime?  @map("scadenza_bollo") @db.Date
  scadenzaRevisione     DateTime?  @map("scadenza_revisione") @db.Date
  scadenzaAssicurazione DateTime?  @map("scadenza_assicurazione") @db.Date
  note                  String?
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  giornate              Giornata[]
  pianificazioni        Pianificazione[]
  attrezzatureUsi       AttrezzaturaUso[]

  @@map("mezzi")
}

enum StatoAttrezzatura {
  disponibile
  in_uso
  in_manutenzione
  fuori_servizio
}

model Attrezzatura {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome         String
  stato        StatoAttrezzatura @default(disponibile)
  assegnatario String?
  note         String?
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  usi          AttrezzaturaUso[]

  @@map("attrezzature")
}

model Materiale {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codice      String?
  descrizione String
  prezzo      Int                 @default(0)
  unita       String?             @default("pz")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  giornate    GiornataMateriale[]
  ordiniRighe OrdineRiga[]
  movimenti   MovimentoMagazzino[]
  richieste   RichiestaMateriale[]

  @@map("materiali")
}

// ─── Preventivi & Commesse ────────────────────────────────────────────────────

enum StatoPreventivo {
  bozza
  inviato
  accettato
  rifiutato
}

model Preventivo {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId String?          @map("cliente_id") @db.Uuid
  cliente   Cliente?         @relation(fields: [clienteId], references: [id])
  data      DateTime         @default(now()) @db.Timestamptz
  stato     StatoPreventivo  @default(bozza)
  note      String?
  righe     PreventivoRiga[]
  commessa  Commessa?
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@map("preventivi")
}

model PreventivoRiga {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  preventivoId   String     @map("preventivo_id") @db.Uuid
  preventivo     Preventivo @relation(fields: [preventivoId], references: [id], onDelete: Cascade)
  descrizione    String
  quantita       Float      @default(1)
  prezzoUnitario Int        @default(0) @map("prezzo_unitario")
  ordine         Int        @default(0)

  @@map("preventivo_righe")
}

enum StatoCommessa {
  aperta
  chiusa
}

model Commessa {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome              String
  clienteId         String?           @map("cliente_id") @db.Uuid
  cliente           Cliente?          @relation(fields: [clienteId], references: [id])
  indirizzoCantiere String?           @map("indirizzo_cantiere")
  stato             StatoCommessa     @default(aperta)
  archiviata        Boolean           @default(false)
  preventivato      Int               @default(0)
  costiMateriali    Int               @default(0) @map("costi_materiali")
  costiManodopera   Int               @default(0) @map("costi_manodopera")
  costiMezzi        Int               @default(0) @map("costi_mezzi")
  fatturato         Int               @default(0)
  preventivoId      String?           @unique @map("preventivo_id") @db.Uuid
  preventivo        Preventivo?       @relation(fields: [preventivoId], references: [id])
  note                   String?
  istruzioniCantiere     String?   @map("istruzioni_cantiere")
  attrezzatureNecessarie String?   @map("attrezzature_necessarie")
  tipoLavoroId      String?           @map("tipo_lavoro_id") @db.Uuid
  tipoLavoro        TipoLavoro?       @relation(fields: [tipoLavoroId], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  operai             CommessaOperaio[]
  giornate           Giornata[]
  pianificazioni     Pianificazione[]
  attrezzatureUsi    AttrezzaturaUso[]
  richiesteMateriale RichiestaMateriale[]
  chatMessaggi       ChatMessaggio[]
  ordini                  OrdineFornitore[]
  movimenti               MovimentoMagazzino[]
  fattureAttive           FatturaAttiva[]
  fatturePassive          FatturaPassiva[]
  dichiarazioniConformita DichiarazioneConformita[]
  richiesteOfferte        RichiestaOfferta[]
  adempimenti             AdempimentoCommessa[]
  proposteIntervento      PropostaIntervento[]

  @@map("commesse")
}

// ─── Fase 2/Redesign: Giornata lavorativa con flusso temporale ───────────────

enum FaseGiornata {
  inizio
  mattina
  pausa
  pomeriggio
  fine
  completata
}

model CommessaOperaio {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commessaId String   @map("commessa_id") @db.Uuid
  commessa   Commessa @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  operaioId  String   @map("operaio_id") @db.Uuid
  operaio    Operaio  @relation(fields: [operaioId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([commessaId, operaioId])
  @@map("commessa_operai")
}

enum StatoGiornata {
  bozza
  inviata
}

enum TipoOra {
  ordinaria
  straordinaria
}

model Giornata {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commessaId        String              @map("commessa_id") @db.Uuid
  commessa          Commessa            @relation(fields: [commessaId], references: [id])
  operaioId         String              @map("operaio_id") @db.Uuid
  operaio           Operaio             @relation(fields: [operaioId], references: [id])
  data              DateTime            @db.Date
  mezzoId           String?             @map("mezzo_id") @db.Uuid
  mezzo             Mezzo?              @relation(fields: [mezzoId], references: [id])
  pianificazioneId  String?             @unique @map("pianificazione_id") @db.Uuid
  pianificazione    Pianificazione?     @relation(fields: [pianificazioneId], references: [id])
  lavoroSvolto      String?             @map("lavoro_svolto")
  note              String?
  stato             StatoGiornata       @default(bozza)
  fase              FaseGiornata        @default(inizio)
  inizioMattina     DateTime?           @map("inizio_mattina") @db.Timestamptz
  fineMattina       DateTime?           @map("fine_mattina") @db.Timestamptz
  inizioPomeriggio  DateTime?           @map("inizio_pomeriggio") @db.Timestamptz
  finePomeriggio    DateTime?           @map("fine_pomeriggio") @db.Timestamptz
  ore               GiornataOra[]
  materiali         GiornataMateriale[]
  foto              GiornataFoto[]
  risposte          ChecklistRisposta[]
  attrezzatureUsi   AttrezzaturaUso[]
  richiesteMateriale RichiestaMateriale[]
  chatMessaggi       ChatMessaggio[]
  rapportino         Rapportino?
  suggerimentoSpunte SuggerimentoSpunta[]
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  @@map("giornate")
}

model GiornataOra {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  giornataId String   @map("giornata_id") @db.Uuid
  giornata   Giornata @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  tipo       TipoOra  @default(ordinaria)
  quantita   Float

  @@map("giornata_ore")
}

model GiornataMateriale {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  giornataId     String     @map("giornata_id") @db.Uuid
  giornata       Giornata   @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  materialeId    String?    @map("materiale_id") @db.Uuid
  materiale      Materiale? @relation(fields: [materialeId], references: [id])
  descrizione    String
  quantita       Float      @default(1)
  prezzoUnitario Int        @default(0) @map("prezzo_unitario")

  @@map("giornata_materiali")
}

model GiornataFoto {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  giornataId String   @map("giornata_id") @db.Uuid
  giornata   Giornata @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  url        String
  path       String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("giornata_foto")
}

model ChecklistTemplate {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domanda   String
  ordine    Int                 @default(0)
  attiva    Boolean             @default(true)
  risposte  ChecklistRisposta[]
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  @@map("checklist_template")
}

model ChecklistRisposta {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  giornataId String            @map("giornata_id") @db.Uuid
  giornata   Giornata          @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  templateId String            @map("template_id") @db.Uuid
  template   ChecklistTemplate @relation(fields: [templateId], references: [id])
  risposta   Boolean
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz

  @@unique([giornataId, templateId])
  @@map("checklist_risposte")
}

// ─── Fase 3: Pianificazione e Assenze ────────────────────────────────────────

enum TipoAssenza {
  ferie
  permesso
  malattia
  altro
}

enum StatoAssenza {
  in_attesa
  approvata
  rifiutata
}

model Pianificazione {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  data            DateTime  @db.Date
  commessaId      String    @map("commessa_id") @db.Uuid
  commessa        Commessa  @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  operaioId       String    @map("operaio_id") @db.Uuid
  operaio         Operaio   @relation(fields: [operaioId], references: [id], onDelete: Cascade)
  mezzoId         String?   @map("mezzo_id") @db.Uuid
  mezzo           Mezzo?    @relation(fields: [mezzoId], references: [id])
  lavoroDaFare    String?   @map("lavoro_da_fare")
  noteMateriale   String?   @map("note_materiale")
  stimaImpresaOre Float?    @map("stima_impresa_ore")
  confermata      Boolean   @default(false)
  sostituito      Boolean   @default(false)
  giornata        Giornata?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([commessaId, operaioId, data])
  @@map("pianificazioni")
}

model Assenza {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operaioId  String       @map("operaio_id") @db.Uuid
  operaio    Operaio      @relation(fields: [operaioId], references: [id], onDelete: Cascade)
  dataInizio DateTime     @map("data_inizio") @db.Date
  dataFine   DateTime     @map("data_fine") @db.Date
  tipo       TipoAssenza  @default(ferie)
  stato      StatoAssenza @default(in_attesa)
  note       String?
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  @@map("assenze")
}

// ─── Fase 2 Redesign: Attrezzatura, Chat, Materiale, Rapportino ──────────────

model AttrezzaturaUso {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attrezzaturaId String       @map("attrezzatura_id") @db.Uuid
  attrezzatura   Attrezzatura @relation(fields: [attrezzaturaId], references: [id])
  operaioId      String       @map("operaio_id") @db.Uuid
  operaio        Operaio      @relation(fields: [operaioId], references: [id])
  commessaId     String       @map("commessa_id") @db.Uuid
  commessa       Commessa     @relation(fields: [commessaId], references: [id])
  mezzoId        String?      @map("mezzo_id") @db.Uuid
  mezzo          Mezzo?       @relation(fields: [mezzoId], references: [id])
  giornataId     String       @map("giornata_id") @db.Uuid
  giornata       Giornata     @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  riconsegnata   Boolean      @default(false)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@map("attrezzatura_usi")
}

enum StatoRichiesta {
  richiesta
  in_preparazione
  consegnata
}

model RichiestaMateriale {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  giornataId  String              @map("giornata_id") @db.Uuid
  giornata    Giornata            @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  commessaId  String              @map("commessa_id") @db.Uuid
  commessa    Commessa            @relation(fields: [commessaId], references: [id])
  operaioId   String              @map("operaio_id") @db.Uuid
  operaio     Operaio             @relation(fields: [operaioId], references: [id])
  materialeId String?             @map("materiale_id") @db.Uuid
  materiale   Materiale?          @relation(fields: [materialeId], references: [id])
  descrizione String
  urgente     Boolean             @default(false)
  stato       StatoRichiesta      @default(richiesta)
  fotoUrl     String?             @map("foto_url")
  fotoPath    String?             @map("foto_path")
  note        String?
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  movimento   MovimentoMagazzino?

  @@map("richieste_materiale")
}

model ChatMessaggio {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commessaId  String   @map("commessa_id") @db.Uuid
  commessa    Commessa @relation(fields: [commessaId], references: [id])
  giornataId  String   @map("giornata_id") @db.Uuid
  giornata    Giornata @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  autoreNome  String   @map("autore_nome")
  ruolo       UserRole
  testo       String?
  fotoUrl     String?  @map("foto_url")
  fotoPath    String?  @map("foto_path")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("chat_messaggi")
}

model Rapportino {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  giornataId           String   @unique @map("giornata_id") @db.Uuid
  giornata             Giornata @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  lavoroEseguito       String   @map("lavoro_eseguito")
  lavoriExtra          String?  @map("lavori_extra")
  noteAttrezzatura     String?  @map("note_attrezzatura")
  noteGiornoSuccessivo String?  @map("note_giorno_successivo")
  oreOrdinarie         Float    @default(0) @map("ore_ordinarie")
  oreStraordinarie     Float    @default(0) @map("ore_straordinarie")
  // Pianificazione giorno successivo (compilata dall'operaio)
  cosaFareDomani       String?  @map("cosa_fare_domani")
  urgenzaDomani        Int?     @map("urgenza_domani")
  stimaOreDomani       Float?   @map("stima_ore_domani")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("rapportini")
}

// ─── Fase 4: Ordini materiale e magazzino ────────────────────────────────────

enum StatoOrdine {
  richiesto
  ordinato
  consegnato
  usato
}

enum TipoMovimento {
  carico
  scarico
  reso
}

model OrdineFornitore {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fornitoreId String?    @map("fornitore_id") @db.Uuid
  fornitore   Fornitore? @relation(fields: [fornitoreId], references: [id])
  commessaId  String?    @map("commessa_id") @db.Uuid
  commessa    Commessa?  @relation(fields: [commessaId], references: [id])
  stato       StatoOrdine @default(richiesto)
  note        String?
  righe          OrdineRiga[]
  movimenti      MovimentoMagazzino[]
  fatturePassive FatturaPassiva[]
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  @@map("ordini_fornitori")
}

model OrdineRiga {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ordineId       String          @map("ordine_id") @db.Uuid
  ordine         OrdineFornitore @relation(fields: [ordineId], references: [id], onDelete: Cascade)
  materialeId    String?         @map("materiale_id") @db.Uuid
  materiale      Materiale?      @relation(fields: [materialeId], references: [id])
  descrizione    String
  quantita       Float           @default(1)
  prezzoUnitario Int             @default(0) @map("prezzo_unitario")

  @@map("ordini_righe")
}

model MovimentoMagazzino {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  materialeId String?          @map("materiale_id") @db.Uuid
  materiale   Materiale?       @relation(fields: [materialeId], references: [id])
  tipo        TipoMovimento
  quantita    Float
  descrizione String?
  commessaId  String?          @map("commessa_id") @db.Uuid
  commessa    Commessa?        @relation(fields: [commessaId], references: [id])
  ordineId    String?          @map("ordine_id") @db.Uuid
  ordine      OrdineFornitore? @relation(fields: [ordineId], references: [id])
  richiestaId String?          @unique @map("richiesta_id") @db.Uuid
  richiesta   RichiestaMateriale? @relation(fields: [richiestaId], references: [id])
  note        String?
  data        DateTime         @default(now()) @db.Timestamptz
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz

  @@map("movimenti_magazzino")
}

// ─── Fase 5: Fatture, DiCo, SdI ──────────────────────────────────────────────

enum StatoFatturaAttiva {
  da_incassare
  incassata
  scaduta
}

enum StatoFatturaPassiva {
  da_pagare
  pagata
}

model FatturaAttiva {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  numero           String
  anno             Int
  data             DateTime           @db.Date
  dataScadenza     DateTime?          @map("data_scadenza") @db.Date
  clienteId        String?            @map("cliente_id") @db.Uuid
  cliente          Cliente?           @relation(fields: [clienteId], references: [id])
  commessaId       String?            @map("commessa_id") @db.Uuid
  commessa         Commessa?          @relation(fields: [commessaId], references: [id])
  stato            StatoFatturaAttiva @default(da_incassare)
  aliquotaIva      Int                @default(22) @map("aliquota_iva")
  note             String?
  dataIncasso      DateTime?          @map("data_incasso") @db.Date
  importoIncassato Int?               @map("importo_incassato")
  righe            FatturaAttivaRiga[]
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([numero, anno])
  @@map("fatture_attive")
}

model FatturaAttivaRiga {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fatturaId      String        @map("fattura_id") @db.Uuid
  fattura        FatturaAttiva @relation(fields: [fatturaId], references: [id], onDelete: Cascade)
  descrizione    String
  quantita       Float         @default(1)
  prezzoUnitario Int           @default(0) @map("prezzo_unitario")
  ordine         Int           @default(0)

  @@map("fattura_attiva_righe")
}

model FatturaPassiva {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fornitoreId   String?            @map("fornitore_id") @db.Uuid
  fornitore     Fornitore?         @relation(fields: [fornitoreId], references: [id])
  commessaId    String?            @map("commessa_id") @db.Uuid
  commessa      Commessa?          @relation(fields: [commessaId], references: [id])
  ordineId      String?            @map("ordine_id") @db.Uuid
  ordine        OrdineFornitore?   @relation(fields: [ordineId], references: [id])
  numero        String?
  data          DateTime           @db.Date
  dataScadenza  DateTime?          @map("data_scadenza") @db.Date
  importo       Int
  stato         StatoFatturaPassiva @default(da_pagare)
  dataPagamento DateTime?          @map("data_pagamento") @db.Date
  importoPagato Int?               @map("importo_pagato")
  note          String?
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  @@map("fatture_passive")
}

model DichiarazioneConformita {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commessaId            String?   @map("commessa_id") @db.Uuid
  commessa              Commessa? @relation(fields: [commessaId], references: [id])
  ragioneSociale        String    @map("ragione_sociale")
  partitaIva            String?   @map("partita_iva")
  indirizzoImpresa      String?   @map("indirizzo_impresa")
  committenteNome       String    @map("committente_nome")
  committenteIndirizzo  String?   @map("committente_indirizzo")
  committenteCodiceFisc String?   @map("committente_codice_fisc")
  indirizzoImpianto     String    @map("indirizzo_impianto")
  tipoImpianto          String    @map("tipo_impianto")
  descrizioneLavori     String    @map("descrizione_lavori")
  tipologiaLavori       String?   @map("tipologia_lavori")
  normativa             String?   @default("CEI 64-8 / DM 37/2008")
  materialiComponenti   String?   @map("materiali_componenti")
  potenzaImpegnata      String?   @map("potenza_impegnata")
  tecnicoNome           String    @map("tecnico_nome")
  tecnicoAbilitazione   String?   @map("tecnico_abilitazione")
  data                  DateTime  @db.Date
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("dichiarazioni_conformita")
}

// ─── Fase 7: Catalogo offerte aggiuntive ─────────────────────────────────────

model OffertaCatalogo {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titolo      String
  categoria   String?
  descrizione String?
  fotoUrl     String?            @map("foto_url")
  fotoPath    String?            @map("foto_path")
  prezzoDa    Int?               @map("prezzo_da")
  attiva      Boolean            @default(true)
  ordine      Int                @default(0)
  richieste   RichiestaOfferta[]
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  @@map("offerte_catalogo")
}

enum StatoRichiestaOfferta {
  nuova
  vista
  in_preventivo
  chiusa
}

model RichiestaOfferta {
  id         String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  offertaId  String                @map("offerta_id") @db.Uuid
  offerta    OffertaCatalogo       @relation(fields: [offertaId], references: [id])
  clienteId  String                @map("cliente_id") @db.Uuid
  cliente    Cliente               @relation(fields: [clienteId], references: [id])
  commessaId String?               @map("commessa_id") @db.Uuid
  commessa   Commessa?             @relation(fields: [commessaId], references: [id])
  note       String?
  stato      StatoRichiestaOfferta @default(nuova)
  createdAt  DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  @@map("richieste_offerte")
}

// ─── Adempimenti di cantiere ─────────────────────────────────────────────────

model TipoLavoro {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome        String
  descrizione String?
  attivo      Boolean              @default(true)
  ordine      Int                  @default(0)
  modelli     AdempimentoModello[]
  commesse    Commessa[]
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  @@map("tipi_lavoro")
}

model AdempimentoModello {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipoLavoroId String              @map("tipo_lavoro_id") @db.Uuid
  tipoLavoro   TipoLavoro          @relation(fields: [tipoLavoroId], references: [id], onDelete: Cascade)
  testo        String
  note         String?
  collegamento String?
  ordine       Int                 @default(0)
  adempimenti  AdempimentoCommessa[]
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  @@map("adempimenti_modello")
}

model AdempimentoCommessa {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commessaId   String              @map("commessa_id") @db.Uuid
  commessa     Commessa            @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  modelloId    String?             @map("modello_id") @db.Uuid
  modello      AdempimentoModello? @relation(fields: [modelloId], references: [id], onDelete: SetNull)
  testo        String
  note         String?
  collegamento String?
  ordine       Int                 @default(0)
  fatto        Boolean             @default(false)
  fattoDa      String?             @map("fatto_da")
  fattoAt      DateTime?           @map("fatto_at") @db.Timestamptz
  notaSpunta   String?             @map("nota_spunta")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  @@map("adempimenti_commessa")
}

// ─── Suggerimenti/promemoria interattivi per operai ──────────────────────────

model SuggerimentoCantiere {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  testo     String
  categoria String?
  ordine    Int      @default(0)
  attivo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  spunte    SuggerimentoSpunta[]

  @@map("suggerimenti_cantiere")
}

model SuggerimentoSpunta {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  suggerimentoId   String               @map("suggerimento_id") @db.Uuid
  suggerimento     SuggerimentoCantiere @relation(fields: [suggerimentoId], references: [id], onDelete: Cascade)
  giornataId       String               @map("giornata_id") @db.Uuid
  giornata         Giornata             @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  completato       Boolean              @default(false)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz

  @@unique([suggerimentoId, giornataId])
  @@map("suggerimenti_spunte")
}

// ─── Libreria task riutilizzabili ────────────────────────────────────────────

model TaskLibreria {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titolo    String
  ordine    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("task_libreria")
}

// ─── Manutenzioni programmate ─────────────────────────────────────────────────

enum TipoImpiantoManutenzione {
  Elettrico
  Allarme
  Automazioni
  Altro
}

enum IntervalloUnita {
  Giorni
  Mesi
}

model ManutenzioneProgrammata {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId              String                   @map("cliente_id") @db.Uuid
  cliente                Cliente                  @relation(fields: [clienteId], references: [id])
  titolo                 String
  tipoImpianto           TipoImpiantoManutenzione @map("tipo_impianto")
  tipoImpiantoAltro      String?                  @map("tipo_impianto_altro")
  intervalloValore       Int                      @map("intervallo_valore")
  intervalloUnita        IntervalloUnita          @map("intervallo_unita")
  dataUltimoIntervento   DateTime?                @map("data_ultimo_intervento") @db.Date
  dataProssimoIntervento DateTime                 @map("data_prossimo_intervento") @db.Date
  note                   String?
  attiva                 Boolean                  @default(true)
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime                 @updatedAt @map("updated_at") @db.Timestamptz
  proposte               PropostaIntervento[]

  @@map("manutenzioni_programmate")
}

// ─── Proposte di intervento (consenso cliente per manutenzioni) ───────────────

enum StatoPropostaIntervento {
  Inviata
  VistaDalCliente
  Accettata
  RifiutataCliente
  ConfermataManuale
  CommessaCreata
  Annullata
}

model PropostaIntervento {
  id                  String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manutenzioneId      String                   @map("manutenzione_id") @db.Uuid
  manutenzione        ManutenzioneProgrammata  @relation(fields: [manutenzioneId], references: [id], onDelete: Cascade)
  clienteId           String                   @map("cliente_id") @db.Uuid
  cliente             Cliente                  @relation(fields: [clienteId], references: [id])
  stato               StatoPropostaIntervento  @default(Inviata)
  messaggioImpresa    String?                  @map("messaggio_impresa")
  dataPropostaPrevista DateTime                @map("data_proposta_prevista") @db.Date
  rispostaCliente     String?                  @map("risposta_cliente")
  confermataDaImpresa Boolean                  @default(false) @map("confermata_da_impresa")
  commessaId          String?                  @map("commessa_id") @db.Uuid
  commessa            Commessa?                @relation(fields: [commessaId], references: [id], onDelete: SetNull)
  dataEsecuzione      DateTime?                @map("data_esecuzione") @db.Date
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime                 @updatedAt @map("updated_at") @db.Timestamptz

  @@map("proposte_intervento")
}

// ─── Stato lettura notifiche ─────────────────────────────────────────────────
// Traccia quali notifiche calcolate (tipo + refId) sono state lette per utente.
// Le notifiche stesse restano calcolate dallo stato DB (nessuna tabella separata).
model NotificaLetta {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  tipo    String
  refId   String   @map("ref_id")
  lettoAt DateTime @default(now()) @map("letto_at") @db.Timestamptz

  @@unique([userId, tipo, refId])
  @@map("notifiche_lette")
}

// ─────────────────────────────────────────────────────────────────────────────
// Configurazione orari di lavoro (un solo record — singleton)
model ConfigurazioneOrari {
  id                     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  durataMattinaMinuti    Int    @default(240) @map("durata_mattina_minuti")
  durataPausaMinuti      Int    @default(60) @map("durata_pausa_minuti")
  durataPomeriggioMinuti Int    @default(240) @map("durata_pomeriggio_minuti")

  @@map("configurazione_orari")
}
